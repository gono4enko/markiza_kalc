# =============================================
# Калькулятор маркиз — пример переменных окружения
# Скопируйте в .env и заполните реальными значениями
# НИКОГДА не добавляйте .env в git!
# =============================================

# ----- Flask -----
SECRET_KEY=замените-на-случайную-строку-минимум-32-символа
FLASK_ENV=production
# FLASK_ENV=development   # раскомментировать для разработки

# ----- База данных PostgreSQL -----
# Формат: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://awning_user:пароль@localhost:5432/awning_db

# ----- Telegram-бот (для уведомлений о лидах) -----
# Получить токен: @BotFather → /newbot
TG_BOT_TOKEN=1234567890:AABBCCDDEEFFGGHHIIJJKKLLMMNNOOPPQQRR
TG_CHAT_ID=-1001234567890

# ----- Email (Gmail SMTP) -----
# Для Gmail нужен App Password: Google-аккаунт → Безопасность → Пароли приложений
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ваш.адрес@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_TO=zakaz@infopergola.ru

# ----- Администраторская панель -----
ADMIN_PASSWORD=замените-на-надёжный-пароль

# ----- Курс EUR/RUB (коэффициент умножения прайса) -----
EURO_RATE=100

# ----- Яндекс.Метрика -----
YM_ID=65714473

# ----- Claude Vision API (OCR прайсов) -----
# Получить токен: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Модель с vision (список: https://docs.anthropic.com/en/docs/about-claude/models)
# ANTHROPIC_OCR_MODEL=claude-sonnet-4-6
# ANTHROPIC_OCR_MODEL=claude-opus-4-5-20251101
